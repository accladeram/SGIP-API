{
  "providers": ["csharp"],
  "variables": {
    "DOTNET_ROOT": "/usr/share/dotnet"
  },
  "phases": {
    "setup": {
      "nixPkgs": ["dotnet-sdk_8"]
    },
    "build": {
      "cmds": [
        "dotnet publish src/SGIP.Presentation/SGIP.Presentation.csproj -c Release -o out"
      ]
    },
    "start": {
      "cmd": "dotnet out/SGIP.Presentation.dll"
    }
  }
}